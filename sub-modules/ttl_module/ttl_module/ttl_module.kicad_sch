	(text "Sub module for the Imperial Debugger.\n\nHas a 2x6 Pin connector as input, which is standard.\nSupplies 5V, 3v3V, 2v5, 1v8 and GND\nAlong with TX, RX, CTS, RTS, DTS\n\nBoard size is 50mm x 19.4mm"
		(exclude_from_sim no)
		(at 38.1 31.75 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "157e688d-b3cf-4c4c-a6ae-b23d0afccea3")
	)
	(text "On Host board\nConnector\nhas\n\nTX       RX\nRTS      CTS\nDTR      TXDEN\nGND      GND\nVBUS     2v5\n1v8      3v3\n"
		(exclude_from_sim no)
		(at 30.48 53.34 0)
		(effects
			(font
				(face "Adwaita Mono")
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "cdeaead1-0960-41cb-8649-daf2cc29561d")
	)
	(text "This Module provides multi-voltage\nTTL compatible I/O\n\nUsing level translators it has TX, RX, CTS, RTS, DTR\n\nJumpers allow mutli voltage selection\nExternal voltage is also allowed.\n\nTX, RTS, DTR are outputs\nRX, CTS are inputs"
		(exclude_from_sim no)
		(at 228.6 26.67 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "cefc4d5a-27d4-4f03-b70e-6d0fe73f5e27")
	)
	(text "On Sub Module board it's\nmirrored  & rotated\nSo connector has\n\n3v3      1v8\n2v5      VBUS\nGND      GND\nTXDEN    DTR\nCTS      RTS\nRX       TX"
		(exclude_from_sim no)
		(at 55.88 53.34 0)
		(effects
			(font
				(face "Adwaita Mono")
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "e3052f91-712e-4e51-be46-4b376f550b34")
	)
